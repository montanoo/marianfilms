---
import '../styles/global.css';

interface Props {
    title: string;
    background?: 'black' | 'white';
    description?: string;
    image?: string;
    noindex?: boolean;
}
const {
    title,
    background = 'black',
    description = 'Marianfilms es el portafolio de Marian Cabezas, cineasta, editora y diseñadora salvadoreña: cortometrajes, videoclips, fotografía y diseño gráfico.',
    image = '/og.jpg',
    noindex = false,
} = Astro.props;
const bodyClass = background === 'white' ? 'bg-white text-black' : 'bg-black text-white';

const site = Astro.site ?? new URL('https://marianfilms.com');
const canonical = new URL(Astro.url.pathname, site);
const ogImage = new URL(image, site);
const fullTitle = /marianfilms/i.test(title) ? title : `${title} | Marianfilms`;
const jsonLd = {
    '@context': 'https://schema.org',
    '@graph': [
        { '@type': 'WebSite', '@id': `${site.origin}/#website`, url: `${site.origin}/`, name: 'Marianfilms', inLanguage: 'es' },
        {
            '@type': 'Person',
            '@id': `${site.origin}/#marian`,
            name: 'Marian Cabezas',
            alternateName: 'Marianfilms',
            url: `${site.origin}/`,
            jobTitle: 'Cineasta, editora y diseñadora',
            sameAs: ['https://instagram.com/marianfilms', 'https://youtube.com/@marianfilms'],
        },
    ],
};
---

<html lang="es" class="scroll-smooth motion-reduce:scroll-auto">
    <head>
        <!-- Set before first paint so CSS can hide reveal targets up front (no
             flash) and the saved language shows immediately. If JS is off this
             never runs: content stays visible and defaults to Spanish. -->
        <script is:inline>
            (function () {
                var root = document.documentElement;
                root.classList.add('js');
                var lang = 'es';
                try {
                    if (localStorage.getItem('lang') === 'en') lang = 'en';
                } catch (e) {}
                root.classList.add('lang-' + lang);
                root.lang = lang;
            })();
        </script>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
        <title>{fullTitle}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonical} />
        <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />

        <meta property="og:type" content="website" />
        <meta property="og:site_name" content="Marianfilms" />
        <meta property="og:title" content={fullTitle} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonical} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:locale" content="es_ES" />
        <meta property="og:locale:alternate" content="en_US" />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={fullTitle} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImage} />

        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    </head>
    <body class={`${bodyClass} p-0 m-0`} id="top">
        <slot />
    </body>
</html>

<script>
    // Global scroll-reveal. Elements start hidden via CSS (html.js, see
    // global.css); GSAP animates them *to* visible, so there's no flash no
    // matter when this client-side module finishes loading.
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!reduce) {
        // Cards / blocks: fade up.
        gsap.utils.toArray<HTMLElement>('.reveal').forEach((el) => {
            gsap.to(el, {
                opacity: 1,
                y: 0,
                duration: 0.8,
                ease: 'power2.out',
                scrollTrigger: { trigger: el, start: 'top 92%', once: true },
            });
        });
        // Gallery images: slower, softer fade from near-transparent.
        gsap.utils.toArray<HTMLElement>('.image-gallery').forEach((el) => {
            gsap.to(el, {
                opacity: 1,
                duration: 1.5,
                ease: 'power2.out',
                scrollTrigger: { trigger: el, start: 'top 90%', once: true },
            });
        });
        // Recompute trigger positions once images have loaded and settled layout
        // (the main reason a gallery-heavy page like /video could look "broken").
        window.addEventListener('load', () => ScrollTrigger.refresh());
    }
</script>