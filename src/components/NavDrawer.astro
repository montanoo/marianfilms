---
// Hamburger trigger + slide-in drawer, shared by Nav (section pages) and Header
// (detail pages). Renders the button inline (the parent's flex row places it on
// the right) plus a fixed, clipped overlay that slides in from the right with
// GSAP — no layout shift. Rendered at most once per page, so its ids stay unique.
import LangToggle from './LangToggle.astro';
import T from './T.astro';
import { ui } from '../i18n';

interface Props {
    active?: 'video' | 'photo' | 'design' | 'about';
}
const { active } = Astro.props;

const links = [
    { label: ui.nav.video, href: '/video', key: 'video' },
    { label: ui.nav.photo, href: '/photo', key: 'photo' },
    { label: ui.nav.design, href: '/design', key: 'design' },
    { label: ui.nav.about, href: '/about', key: 'about' },
];
const linkClass = (key: string) =>
    [
        'font-bold tracking-wide text-2xl hover:opacity-70 transition-opacity',
        active === key ? 'underline underline-offset-[6px]' : '',
    ].join(' ');
---

<button
    id="nav-toggle"
    type="button"
    aria-label="Open menu"
    aria-controls="nav-menu"
    aria-expanded="false"
    class="cursor-pointer p-1 -mr-1"
>
    <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="7" x2="21" y2="7" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="17" x2="21" y2="17" />
    </svg>
</button>

<!-- Drawer overlay. text-white pins the panel's colors regardless of the page's
     logo color, since the panel is always dark. -->
<div id="nav-menu" class="hidden fixed inset-0 z-50 overflow-hidden text-white">
    <div id="nav-backdrop" class="absolute inset-0 bg-black/60"></div>
    <aside class="nav-panel absolute top-0 right-0 flex h-full w-[82%] max-w-xs flex-col overflow-y-auto bg-black px-6 pt-6 pb-10">
        <button id="nav-close" type="button" aria-label="Close menu" class="self-end cursor-pointer p-1">
            <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <line x1="5" y1="5" x2="19" y2="19" />
                <line x1="19" y1="5" x2="5" y2="19" />
            </svg>
        </button>
        <div class="mt-8 flex flex-col gap-7">
            {links.map((l) => <a href={l.href} class={linkClass(l.key)}><T value={l.label} /></a>)}
        </div>
        <div class="mt-10"><LangToggle /></div>
    </aside>
</div>

<script>
    import gsap from 'gsap';

    const btn = document.getElementById('nav-toggle');
    const closeBtn = document.getElementById('nav-close');
    const menu = document.getElementById('nav-menu');
    const backdrop = document.getElementById('nav-backdrop');
    const panel = menu?.querySelector<HTMLElement>('.nav-panel');

    if (btn && menu && backdrop && panel) {
        const dur = window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 0 : 1;

        // Park off the right edge; the overlay's overflow-hidden clips it, so it
        // never widens the page (no horizontal scroll, no layout shift).
        gsap.set(panel, { xPercent: 100 });
        gsap.set(backdrop, { autoAlpha: 0 });

        const tl = gsap
            .timeline({ paused: true, onReverseComplete: () => menu.classList.add('hidden') })
            .to(backdrop, { autoAlpha: 1, duration: 0.25 * dur, ease: 'power1.out' }, 0)
            .to(panel, { xPercent: 0, duration: 0.4 * dur, ease: 'power3.out' }, 0);

        const open = () => {
            menu.classList.remove('hidden');
            btn.setAttribute('aria-expanded', 'true');
            tl.play();
        };
        const close = () => {
            btn.setAttribute('aria-expanded', 'false');
            tl.reverse();
        };

        btn.addEventListener('click', open);
        closeBtn?.addEventListener('click', close);
        backdrop.addEventListener('click', close);
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && btn.getAttribute('aria-expanded') === 'true') close();
        });
    }
</script>
