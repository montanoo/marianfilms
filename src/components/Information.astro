---
import T from './T.astro';
import type { Localized } from '../i18n';

const ALIGN = {
    left: 'text-left',
    center: 'text-center',
    right: 'text-right',
} as const;

interface Item {
    term: Localized;
    description?: Localized;
}

interface Props {
    title: Localized;
    items: Item[];
    alignment?: keyof typeof ALIGN;
    /** Bold the section heading. */
    boldTitle?: boolean;
    /** Bold each term (`<dt>`). */
    boldTerms?: boolean;
    /** Constrain + center the whole block (used inside the image grid). */
    constrain?: boolean;
    /** Shown when an item has no description. */
    fallback?: Localized;
}

const {
    title,
    items,
    alignment = 'left',
    boldTitle = true,
    boldTerms = true,
    constrain = false,
    fallback = '',
} = Astro.props;

const align = ALIGN[alignment];
const underline = alignment === 'left';
---

{items.length > 0 && (
    <div class:list={[constrain && 'max-w-80 mx-auto']}>
        <h2 class:list={['text-[24px] mt-5', align, boldTitle && 'font-bold', underline && 'underline']}>
            <T value={title} />
        </h2>
        <dl>
            {items.map(({ term, description }) => (
                <>
                    <dt class:list={['text-[25px] leading-8', align, boldTerms ? 'font-bold' : 'font-normal']}><T value={term} /></dt>
                    <dd class:list={['text-white/80 font-extralight text-[25px] leading-8', align]}><T value={description || fallback} /></dd>
                </>
            ))}
        </dl>
    </div>
)}
