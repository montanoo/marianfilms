---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import T from './T.astro';
import type { Localized } from '../i18n';

interface RowItem {
    src: ImageMetadata;
    span?: number;
    heading?: Localized;
    caption?: Localized;
}

interface BlockItem {
    rows: ImageMetadata[][]; // each row = images side by side; rows stack vertically
    heading?: Localized; // rendered above the images, at content-left
    caption?: Localized; // rendered below the images
    gap?: number; // horizontal gap between images within a row
    rowGap?: number; // vertical gap between stacked rows
}

interface GridItem {
    src: ImageMetadata;
    col: string;
    row?: string;
    ar?: number;
}

interface ColItem {
    src: ImageMetadata;
    w?: number;
}

interface ColumnDef {
    width: number;
    align: 'start' | 'center' | 'end';
    rows: ColItem[][];
}

interface SectionRowItem {
    src: ImageMetadata;
    span?: number;
    ar?: number;
    w?: number;
}

interface SectionColItem {
    src: ImageMetadata;
    w?: number;
    ar?: number;
    fill?: boolean;
}

interface SectionColumn {
    width: number;
    align: 'start' | 'center' | 'end';
    rows: SectionColItem[][];
}

interface Section {
    row?: SectionRowItem[];
    columns?: SectionColumn[];
    width?: number;
    gap?: number;
    justify?: 'start' | 'center' | 'end' | 'between' | 'around';
    valign?: 'start' | 'center' | 'end';
    colGap?: number;
    pairGap?: number;
    rowGap?: number;
}

interface Props {
    title: string;
    layout?: 'rows' | 'grid' | 'columns' | 'sections' | 'blocks';
    rows?: RowItem[][];
    blocks?: BlockItem[];
    blockGap?: number;
    grid?: GridItem[];
    gridCols?: number;
    gridTemplate?: string;
    gridGap?: number;
    columns?: ColumnDef[];
    colGap?: number;
    pairGap?: number;
    rowGap?: number;
    singleWidth?: number;
    captionAlign?: 'center' | 'left';
    leadGap?: number;
    sections?: Section[];
    sectionGap?: number;
    /** Mobile (<md): collapse the authored layout into a 2-column staggered masonry. */
    mobileMasonry?: boolean;
    /** Masonry left-column flex-grow (1 = equal columns; >1 = bigger left). */
    masonryLeftBias?: number;
}

const {
    title,
    layout = 'rows',
    rows = [],
    blocks = [],
    blockGap = 0,
    grid = [],
    gridCols = 6,
    gridTemplate,
    gridGap = 14,
    columns = [],
    colGap = 14,
    pairGap = 14,
    rowGap = 67,
    singleWidth = 72,
    captionAlign = 'center',
    leadGap,
    sections = [],
    sectionGap = 28,
    mobileMasonry = false,
    masonryLeftBias = 1,
} = Astro.props;

const JUSTIFY = { start: 'flex-start', center: 'center', end: 'flex-end' } as const;
const FLOW = { start: 'flex-start', center: 'center', end: 'flex-end', between: 'space-between', around: 'space-around' } as const;

const aspect = (img: ImageMetadata) => img.width / img.height;

const ROW_UNIT = 14;
const cols = gridTemplate
    ? gridTemplate.split(/\s+/).map(Number).filter((v) => !Number.isNaN(v))
    : [];
const templateCols = cols.length
    ? cols.map((c) => `${c}fr`).join(' ')
    : `repeat(${gridCols},minmax(0,1fr))`;

function colSpanWidth(col: string): number {
    const m = col.match(/(\d+)\s*\/\s*(\d+)/);
    const total = cols.reduce((a, b) => a + b, 0);
    if (!m || !cols.length) return total;
    const start = Number(m[1]) - 1;
    const end = Number(m[2]) - 1;
    let w = 0;
    for (let i = start; i < end; i++) w += cols[i] || 0;
    return w + Math.max(0, end - start - 1) * gridGap;
}

function gridRow(item: GridItem): string {
    if (item.row) return item.row;
    const w = colSpanWidth(item.col);
    const h = w / (item.ar || aspect(item.src));
    const span = Math.max(1, Math.round((h + gridGap) / (ROW_UNIT + gridGap)));
    return `span ${span}`;
}

let n = 0;

const masonryImages: ImageMetadata[] = [];
for (const row of rows) for (const it of row) masonryImages.push(it.src);
for (const it of grid) masonryImages.push(it.src);
for (const col of columns) for (const r of col.rows) for (const it of r) masonryImages.push(it.src);
for (const sec of sections) {
    if (sec.row) for (const it of sec.row) masonryImages.push(it.src);
    if (sec.columns) for (const sc of sec.columns) for (const r of sc.rows) for (const it of r) masonryImages.push(it.src);
}
const leftParity = (masonryImages.length - 1) % 2;
const leftCol = masonryImages.filter((_, i) => i % 2 === leftParity);
const rightCol = masonryImages.filter((_, i) => i % 2 !== leftParity);
---

{mobileMasonry && masonryImages.length > 0 && (
    <div class="flex gap-2.5 md:hidden">
        <div class="flex min-w-0 flex-col gap-2.5" style={`flex:${masonryLeftBias} 1 0`}>
            {leftCol.map((img, i) => (
                <Image src={img} alt={`${title} — L${i + 1}`} class="image-gallery block w-full h-auto" />
            ))}
        </div>
        <div class="flex flex-1 min-w-0 flex-col gap-2.5">
            {rightCol.map((img, i) => (
                <Image src={img} alt={`${title} — R${i + 1}`} class="image-gallery block w-full h-auto" />
            ))}
        </div>
    </div>
)}

<div class:list={[mobileMasonry && 'hidden md:block']}>
{layout === 'blocks' ? (
    <div class="flex flex-col" style={`gap:${blockGap}px`}>
        {blocks.map((block) => (
            <div>
                {block.heading && (
                    <h3 class="text-xl md:text-2xl font-bold mb-4 md:mb-6"><T value={block.heading} /></h3>
                )}
                <figure
  class="m-0 mx-auto flex w-full flex-col max-w-[var(--mobile-width)] md:max-w-[60%]"
  style={`--mobile-width:${singleWidth}%; gap:${block.rowGap ?? 14}px;`}
>
                    {block.rows.map((row) => (
                        <div class="flex" style={`gap:${block.gap ?? 0}px`}>
                            {row.map((img) => {
                                n++;
                                // A lone image must fill its row, so it gets flex-grow:1.
                                // (A grow factor below 1 would only fill that fraction of
                                // the row — portrait images, aspect < 1, would look undersized.)
                                // Multi-image rows keep aspect weights to size proportionally.
                                return (
                                    <div class="min-w-0" style={`flex-grow:${row.length === 1 ? 1 : aspect(img)}; flex-basis:0`}>
                                        <Image src={img} alt={`${title} — ${n}`} class="image-gallery block w-full h-auto" />
                                    </div>
                                );
                            })}
                        </div>
                    ))}
                    {block.caption && (
                        <figcaption class={captionAlign === 'left' ? 'w-full' : 'mx-auto max-w-[80%]'}>
                            <p class={`leading-relaxed ${captionAlign === 'left' ? 'text-base md:text-lg opacity-90' : 'text-sm md:text-base opacity-80'}`}><T value={block.caption} html /></p>
                        </figcaption>
                    )}
                </figure>
            </div>
        ))}
    </div>
) : layout === 'sections' ? (
    <div class="flex flex-col" style={`gap:${sectionGap}px`}>
        {sections.map((section) => {
            if (section.columns) {
                const cg = section.colGap ?? colGap;
                const pg = section.pairGap ?? pairGap;
                const rg = section.rowGap ?? rowGap;
                return (
                    <div class="flex items-stretch" style={`gap:${cg}px`}>
                        {section.columns.map((column) => (
                            <div class="flex flex-col min-h-0" style={`flex:${column.width} 1 0; gap:${rg}px`}>
                                {column.rows.map((row) => {
                                    if (row.length === 1) {
                                        n++;
                                        const it = row[0];
                                        if (it.fill) {
                                            return (
                                                <div class="flex flex-1 min-h-0" style={`justify-content:${JUSTIFY[column.align]}`}>
                                                    <div class="relative h-full" style={`width:${(it.w ?? 1) * 100}%`}>
                                                        <Image src={it.src} alt={`${title} — ${n}`} class="image-gallery absolute inset-0 h-full w-full object-cover" />
                                                    </div>
                                                </div>
                                            );
                                        }
                                        return (
                                            <div class="flex" style={`justify-content:${JUSTIFY[column.align]}`}>
                                                <div style={`width:${(it.w ?? 1) * 100}%`}>
                                                    {it.ar ? (
                                                        <Image src={it.src} alt={`${title} — ${n}`} class="image-gallery block w-full object-cover" style={`aspect-ratio:${it.ar}`} />
                                                    ) : (
                                                        <Image src={it.src} alt={`${title} — ${n}`} class="image-gallery block w-full h-auto" />
                                                    )}
                                                </div>
                                            </div>
                                        );
                                    }
                                    return (
                                        <div class="flex items-start" style={`gap:${pg}px`}>
                                            {row.map((item) => {
                                                n++;
                                                return (
                                                    <figure class="m-0 min-w-0" style={`flex-grow:${item.ar ?? aspect(item.src)}; flex-basis:0`}>
                                                        {item.ar ? (
                                                            <Image src={item.src} alt={`${title} — ${n}`} class="image-gallery block w-full object-cover" style={`aspect-ratio:${item.ar}`} />
                                                        ) : (
                                                            <Image src={item.src} alt={`${title} — ${n}`} class="image-gallery block w-full h-auto" />
                                                        )}
                                                    </figure>
                                                );
                                            })}
                                        </div>
                                    );
                                })}
                            </div>
                        ))}
                    </div>
                );
            }

            const row = section.row ?? [];
            if (row.length === 1) {
                n++;
                const it = row[0];
                return (
                    <div class="mx-auto w-full" style={`max-width:${section.width ?? singleWidth}%`}>
                        {it.ar ? (
                            <Image src={it.src} alt={`${title} — ${n}`} class="image-gallery block w-full object-cover" style={`aspect-ratio:${it.ar}`} />
                        ) : (
                            <Image src={it.src} alt={`${title} — ${n}`} class="image-gallery block w-full h-auto" />
                        )}
                    </div>
                );
            }
            return (
                <div class="flex" style={`gap:${section.gap ?? 32}px; justify-content:${FLOW[section.justify ?? 'start']}; align-items:${JUSTIFY[section.valign ?? 'start']}`}>
                    {row.map((item) => {
                        n++;
                        const sizing = item.w != null
                            ? `width:${item.w * 100}%; flex:none`
                            : `flex-grow:${item.span ?? item.ar ?? aspect(item.src)}; flex-basis:0`;
                        return (
                            <figure class="m-0 min-w-0" style={sizing}>
                                {item.ar ? (
                                    <Image src={item.src} alt={`${title} — ${n}`} class="image-gallery block w-full object-cover" style={`aspect-ratio:${item.ar}`} />
                                ) : (
                                    <Image src={item.src} alt={`${title} — ${n}`} class="image-gallery block w-full h-auto" />
                                )}
                            </figure>
                        );
                    })}
                </div>
            );
        })}
    </div>
) : layout === 'grid' ? (
    <div
        class="grid"
        style={`grid-template-columns:${templateCols}; grid-auto-rows:${ROW_UNIT}px; gap:${gridGap}px; grid-auto-flow:row dense;`}
    >
        {grid.map((item) => {
            n++;
            return (
                <Image
                    src={item.src}
                    alt={`${title} — ${n}`}
                    class="image-gallery block h-full w-full object-cover"
                    style={`grid-column:${item.col}; grid-row:${gridRow(item)};`}
                />
            );
        })}
    </div>
) : layout === 'columns' ? (
    <div class="flex items-start" style={`gap:${colGap}px`}>
        {columns.map((column) => (
            <div class="flex flex-col" style={`flex:${column.width} 1 0; gap:${rowGap}px`}>
                {column.rows.map((row) => {
                    if (row.length === 1) {
                        n++;
                        return (
                            <div class="flex" style={`justify-content:${JUSTIFY[column.align]}`}>
                                <div style={`width:${(row[0].w ?? 1) * 100}%`}>
                                    <Image src={row[0].src} alt={`${title} — ${n}`} class="image-gallery block w-full h-auto" />
                                </div>
                            </div>
                        );
                    }
                    return (
                        <div class="flex" style={`gap:${pairGap}px`}>
                            {row.map((item) => {
                                n++;
                                return (
                                    <figure class="m-0 min-w-0" style={`flex-grow:${aspect(item.src)}; flex-basis:0`}>
                                        <Image src={item.src} alt={`${title} — ${n}`} class="image-gallery block w-full h-auto" />
                                    </figure>
                                );
                            })}
                        </div>
                    );
                })}
            </div>
        ))}
    </div>
) : (
    <div class="flex flex-col">
        {rows.map((row, i) => {
            const mb = i === rows.length - 1 ? 0 : i === 0 && leadGap != null ? leadGap : rowGap;
            const mbStyle = `margin-bottom:${mb}px`;

            if (row.length === 1) {
                n++;
                const it = row[0];
                return (
                    <div class="mx-auto w-full" style={`max-width:${singleWidth}%; ${mbStyle}`}>
                        <Image src={it.src} alt={`${title} — ${n}`} class="image-gallery block w-full h-auto" />
                        {(it.heading || it.caption) && (
                            <figcaption class="mt-3 md:mt-4">
                                {it.heading && <h3 class="text-lg md:text-xl font-bold"><T value={it.heading} /></h3>}
                                {it.caption && <p class="text-sm md:text-base opacity-80 leading-relaxed mt-1"><T value={it.caption} html /></p>}
                            </figcaption>
                        )}
                    </div>
                );
            }

            return (
                <div class="flex gap-4 md:gap-8" style={mbStyle}>
                    {row.map((item) => {
                        n++;
                        return (
                            <figure class="m-0 min-w-0" style={`flex-grow:${item.span ?? aspect(item.src)}; flex-basis:0`}>
                                <Image src={item.src} alt={`${title} — ${n}`} class="image-gallery block w-full h-auto" />
                            </figure>
                        );
                    })}
                </div>
            );
        })}
    </div>
)}
</div>

<!-- Reveal handled globally by Base.astro (.image-gallery). -->

