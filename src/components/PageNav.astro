---
import T from './T.astro';
import { ui } from '../i18n';
import type { Localized } from '../i18n';

interface Props {
    moreHref?: string;
    moreLabel?: Localized;
}

const { moreHref = '/video', moreLabel = ui.moreVideos } = Astro.props;

const links = [
    { href: moreHref, label: moreLabel },
    { href: '#top', label: ui.backToTop },
    { href: '/', label: ui.backToHome },
];
---

<nav class="grid grid-cols-3 mt-10">
    {links.map(({ href, label }) => (
        <a href={href} class="font-bold text-center text-xs sm:text-base"><T value={label} /></a>
    ))}
</nav>
