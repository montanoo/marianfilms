---
import LogoMark from '../assets/logo.svg';
import LangToggle from './LangToggle.astro';
import NavDrawer from './NavDrawer.astro';
import T from './T.astro';
import { ui } from '../i18n';

interface Props {
    /** Slug of the active section, e.g. "video". */
    active?: 'video' | 'photo' | 'design' | 'about';
}

const { active = 'video' } = Astro.props;

const links = [
    { label: ui.nav.video, href: '/video', key: 'video' },
    { label: ui.nav.photo, href: '/photo', key: 'photo' },
    { label: ui.nav.design, href: '/design', key: 'design' },
    { label: ui.nav.about, href: '/about', key: 'about' },
];
const left = links.slice(0, 2);
const right = links.slice(2);

const linkClass = (key: string) =>
    [
        'font-bold tracking-wide hover:opacity-70 transition-opacity',
        active === key ? 'underline underline-offset-[6px]' : '',
    ].join(' ');
---

<nav class="sticky top-0 z-50 bg-black">
    <!-- Desktop (lg+): links · logo · links + toggle -->
    <div class="hidden lg:grid px-5 md:px-10 xl:max-w-[1680px] mx-auto py-6 xl:py-8 grid-cols-[1fr_auto_1fr] items-center">
        <div class="flex items-center gap-8 md:gap-14 xl:gap-20">
            {left.map((l) => <a href={l.href} class={linkClass(l.key)}><T value={l.label} /></a>)}
        </div>

        <a href="/" aria-label="Marian Cabezas — home" class="justify-self-center">
            <LogoMark class="h-10 w-auto xl:h-14" />
        </a>

        <div class="flex items-center justify-end gap-8 md:gap-14 xl:gap-20">
            {right.map((l) => <a href={l.href} class={linkClass(l.key)}><T value={l.label} /></a>)}
            <LangToggle />
        </div>
    </div>

    <!-- Tablet / mobile (< lg): logo left, hamburger right -->
    <div class="lg:hidden px-5 md:px-10">
        <div class="flex items-center justify-between py-5">
            <a href="/" aria-label="Marian Cabezas — home">
                <LogoMark class="h-7 w-auto" />
            </a>
            <NavDrawer active={active} />
        </div>
    </div>
</nav>
