---
import LogoMark from '../assets/logo.svg';
import ArrowMark from '../assets/arrow.svg';
interface Props { text?: string}

const { text } = Astro.props;
---

<header class="relative">
    <ArrowMark class="absolute left-0 top-1/2 -translate-y-1/2 w-10 h-8xl:w-22 xl:h-20 text-white rotate-90"/>
    <div class="flex flex-col justify-center items-center gap-2">
        <LogoMark class="w-10 h-5 xl:w-25 xl:h-15" />
        {text && <span class="text-xs xl:text-base font-extralight xl:tracking-[1.1em] xl:mr-[-1.1em]">{text}</span>}
    </div>
</header>
