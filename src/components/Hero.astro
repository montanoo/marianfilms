---
import CameraText from '../assets/camera-with-text.svg';
import Arrow from '../assets/arrow.svg';
---

<section
    id="hero"
    class="relative h-screen overflow-hidden text-black"
    style="background: linear-gradient(to bottom, #ffffff 0%, #ffffff 76%, #000000 100%);"
>
    <div id="hero-logo" class="absolute inset-0 flex items-center justify-center will-change-transform">
        <!-- Optical centering: the mark reads left-heavy when geometrically
             centered, so nudge it slightly right. Offset lives on the SVG (not
             #hero-logo, whose transform GSAP drives) to avoid clobbering it. -->
        <CameraText class="w-44 h-auto xl:w-72 translate-x-[5.5%]" />
    </div>

    <Arrow class="hero-arrow absolute bottom-36 left-8 w-6 xl:bottom-44 xl:left-16 xl:w-9 text-black" />
    <Arrow class="hero-arrow absolute bottom-36 right-8 w-6 xl:bottom-44 xl:right-16 xl:w-9 text-black" />
</section>

<script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    const logo = '#hero-logo';
    const arrows = '.hero-arrow';

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        gsap.set([logo, arrows], { opacity: 1 });
    } else {
        gsap.set([logo, arrows], { opacity: 0 });

        gsap.timeline()
            .to(logo, { opacity: 1, duration: 4, ease: 'power2.out' })
            .to(arrows, { opacity: 1, duration: 0.8, ease: 'power2.out' }, '<0.5')
            .call(() => {
                gsap.to(arrows, {
                    y: 9,
                    duration: 0.7,
                    ease: 'sine.inOut',
                    repeat: -1,
                    yoyo: true,
                });

                const scrub = {
                    trigger: '#hero',
                    start: 'top top',
                    end: 'bottom top',
                    scrub: true,
                };

                gsap.to(logo, { scrollTrigger: scrub, y: -140, scale: 0.45, opacity: 0, ease: 'none' });
                gsap.to(arrows, { scrollTrigger: scrub, opacity: 0, ease: 'none' });
            }, undefined, '>');
    }
</script>
