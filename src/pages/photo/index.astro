---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import T from '../../components/T.astro';
import { pick } from '../../i18n';

const photos = (await getCollection('photo')).sort(
    (a, b) => a.data.order - b.data.order,
);
---

<Base title="Photo">
    <Nav active="photo" />
    <main class="px-5 md:px-10 xl:max-w-[1680px] mx-auto py-10 xl:py-16 pb-20 xl:pb-32">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-2.5 md:gap-3">
            {photos.map((photo) => (
                <a
                    href={`/photo/${photo.id}`}
                    class="reveal group relative block aspect-[3/4] overflow-hidden"
                >
                    <Image
                        src={photo.data.thumbnail}
                        alt={pick(photo.data.title)}
                        class="h-full w-full object-cover transition duration-500 ease-out group-hover:scale-[1.03] group-hover:brightness-[0.35]"
                    />
                    <div class="absolute inset-0 flex flex-col items-center justify-center gap-1.5 p-4 text-center opacity-0 transition-opacity duration-500 group-hover:opacity-100 group-focus-visible:opacity-100">
                        <h3 class="font-light uppercase tracking-[0.3em] pl-[0.3em] text-xl md:text-2xl leading-tight"><T value={photo.data.cardTitle ?? photo.data.title} /></h3>
                        <p class="text-[10px] md:text-[11px] uppercase tracking-[0.3em] pl-[0.3em] text-white/70"><T value={photo.data.label} /></p>
                    </div>
                </a>
            ))}
        </div>
    </main>
</Base>
