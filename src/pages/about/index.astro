---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import T from '../../components/T.astro';
import { ui } from '../../i18n';
import type { Localized } from '../../i18n';
import { Image } from 'astro:assets';
import CameraText from '../../assets/camera-with-text.svg';
import portrait from './gallery/still-1.jpg';
import ceremony from './gallery/still-2.jpg';
import EmailIcon from '../../assets/email.svg';
import InstagramIcon from '../../assets/instagram.svg';
import YoutubeIcon from '../../assets/youtube.svg';
import PhoneIcon from '../../assets/phone.svg';

const bio: Localized[] = [
    {
        en: "I'm Marian Cabezas, a filmmaker, editor, designer, and communications professional passionate about visual storytelling. Through film, music videos, design, and digital media, I aim to portray abstract emotions through unique experiences, heavily centered on the female side and their day-to-day complex minds.",
        es: "Soy Marian Cabezas, cineasta, editora, diseñadora y profesional de la comunicación, apasionada por la narración visual. A través del cine, los videoclips, el diseño y los medios digitales, busco plasmar emociones abstractas mediante experiencias únicas, con especial énfasis en la perspectiva femenina y la complejidad de su mente en el día a día.",
    },
    {
        en: "I graduated from Universidad Dr. José Matías Delgado with a bachelor's degree in communications. This is where I developed my skills in graphic design and strategic communication.",
        es: "Me gradué de la Universidad Dr. José Matías Delgado con una licenciatura en Comunicación. Allí desarrollé mis habilidades en diseño gráfico y comunicación estratégica.",
    },
    {
        en: "Over the years, I have worked in creative roles and collaborated with festivals and independent artists. My experience ranges from directing short films and music videos to leading creative teams, developing visual identities, managing social media campaigns, and producing multimedia content.",
        es: "A lo largo de los años, he trabajado en roles creativos y colaborado con festivales y artistas independientes. Mi experiencia abarca desde la dirección de cortometrajes y videoclips hasta la dirección de equipos creativos, el desarrollo de identidades visuales, la gestión de campañas en redes sociales y la producción de contenido multimedia.",
    },
];

interface Entry { year: string; title: Localized; sub: Localized; }

const awards: Entry[] = [
    {
        year: '2025',
        title: { en: 'Honorable Mention, Mónica Herrera Audiovisual Festival', es: 'Mención Honorífica, Festival Audiovisual Mónica Herrera' },
        sub: { en: 'Fiction Short Film: Subibajas', es: 'Cortometraje de Ficción: Subibajas' },
    },
    {
        year: '2025',
        title: { en: 'Best Sound, Thirza Ruballo Award, 6th ESCINE Short Film Festival', es: 'Mejor Sonido, Premio Thirza Ruballo, 6º Festival de Cortos ESCINE' },
        sub: { en: 'Fiction Short Film: Yamevú', es: 'Cortometraje de Ficción: Yamevú' },
    },
    {
        year: '2025',
        title: { en: 'Best Makeup, Thirza Ruballo Award, 6th ESCINE Short Film Festival', es: 'Mejor Maquillaje, Premio Thirza Ruballo, 6º Festival de Cortos ESCINE' },
        sub: { en: 'Fiction Short Film: Yamevú', es: 'Cortometraje de Ficción: Yamevú' },
    },
    {
        year: '2024',
        title: { en: 'Best Music Video, Mónica Herrera Audiovisual Festival', es: 'Mejor Video Musical, Festival Audiovisual Mónica Herrera' },
        sub: { en: 'Music Video: CUÁNTOS', es: 'Video Musical: CUANTOS' },
    },
    {
        year: '2024',
        title: { en: 'Best Director, Torogoz Film Festival', es: 'Mejor Directora, Festival Torogoz' },
        sub: { en: 'Universidad Dr. José Matías Delgado', es: 'Universidad Dr. José Matías Delgado' },
    },
    {
        year: '2023',
        title: { en: 'Best Sound, Thirza Ruballo Award, 4th ESCINE Short Film Festival', es: 'Mejor Sonido, Premio Thirza Ruballo, 4º Festival de Cortos ESCINE' },
        sub: { en: 'Fiction Short Film: Amargo', es: 'Cortometraje de Ficción: Amargo' },
    },
];

const exhibitions: Entry[] = [
    {
        year: '2023, 2025',
        title: { en: 'ESCINE – Official Selection', es: 'ESCINE – Selección Oficial' },
        sub: { en: 'Screened at Cinépolis El Salvador.', es: 'Exhibición en Cinépolis El Salvador.' },
    },
    {
        year: '2025',
        title: { en: 'International Showcase – Yucatán, México', es: 'Muestra Internacional – Yucatán, México' },
        sub: { en: 'Salvadoran cinema screening at Cineteca del Teatro Armando Manzanero.', es: 'Exhibición de cine salvadoreño en Cineteca del Teatro Armando Manzanero.' },
    },
];
---

<Base title="About Me">
    <Nav active="about" />

    <main class="px-5 md:px-10 xl:max-w-[1680px] mx-auto pt-6 xl:pt-10 pb-16 xl:pb-28">
        <!-- Intro: portrait + bio -->
        <section class="grid gap-8 md:grid-cols-[1fr_2fr] xl:gap-10 md:items-end">
            <Image src={portrait} alt="Marian Cabezas" class="w-full h-auto" />

            <div class="max-w-4xl">
                <h1 class="text-sm tracking-[0.4em] mb-6"><T value={ui.aboutMe} /></h1>
                <div class="space-y-4 font-extralight leading-7 text-[21px] xl:text-base opacity-90">
                    {bio.map((p) => <p><T value={p} /></p>)}
                </div>
                <div class="mt-2">
                    <a data-lang="es" href="/CV_MARIANCABEZAS_ES.pdf" download class="font-medium tracking-wide text-[#c63636] hover:opacity-70 underline">{ui.downloadCv.es}</a>
                    <a data-lang="en" href="/CV_MARIANCABEZAS_ENG.pdf" download class="font-medium tracking-wide text-[#c63636] hover:opacity-70 underline">{ui.downloadCv.en}</a>
                    <p class="mt-1 text-xs opacity-60"><T value={ui.cvNote} /></p>
                </div>
            </div>
        </section>

        <!-- Awards + Exhibitions -->
        <section class="mt-20 grid gap-10 md:grid-cols-[minmax(0,586px)_1fr] xl:mt-28 xl:gap-16 md:items-start">
            <!-- Awards -->
            <div>
                <h2 class="text-[28px] font-bold underline underline-offset-4 mb-7"><T value={ui.recognitions} /></h2>
                <ul class="space-y-6">
                    {awards.map((a) => (
                        <li>
                            <p class="text-[25px] opacity-60">{a.year}</p>
                            <p class="text-[25px] font-bold leading-snug"><T value={a.title} /></p>
                            <p class="text-[25px] opacity-60"><T value={a.sub} /></p>
                        </li>
                    ))}
                </ul>
            </div>

            <!-- Award photo + Exhibitions -->
            <div class="flex flex-col justify-between h-full">
                <Image src={ceremony} alt="Marian Cabezas receiving an award" class="w-full h-auto" />
                <div>
                <h2 class="text-[28px] font-bold underline underline-offset-4 mt-10 mb-7"><T value={ui.exhibitions} /></h2>
                    <ul class="space-y-6">
                        {exhibitions.map((e) => (
                            <li class="underline decoration-1 underline-offset-4">
                                <p class="text-sm">{e.year}</p>
                                <p class="text-[25px] font-bold leading-snug"><T value={e.title} /></p>
                                <p class="text-[25px]"><T value={e.sub} /></p>
                            </li>
                        ))}
                    </ul>
                </div>
            </div>
        </section>
    </main>

    <!-- Footer -->
    <footer class="bg-white text-black">
        <div class="px-5 md:px-10 xl:max-w-[1680px] mx-auto py-16 xl:py-24">
            <div class="grid gap-12 md:grid-cols-2 md:items-center">
                <CameraText class="h-56 w-auto xl:h-64 md:justify-self-center" />

                <div>
                    <h2 class="text-sm tracking-[0.4em] mb-8"><T value={ui.contact} /></h2>
                    <ul class="space-y-5 text-lg">
                        <li class="flex items-center gap-4">
                            <EmailIcon class="h-7 w-auto" />
                            <a href="mailto:marianromero234@gmail.com" class="hover:opacity-70">marianromero234@gmail.com</a>
                        </li>
                        <li class="flex items-center gap-4">
                            <a href="https://instagram.com/marianfilms" target="_blank" rel="noopener" aria-label="Instagram" class="hover:opacity-70">
                                <InstagramIcon class="h-7 w-auto" />
                            </a>
                            <a href="https://youtube.com/@marianfilms" target="_blank" rel="noopener" aria-label="YouTube" class="hover:opacity-70">
                                <YoutubeIcon class="h-7 w-auto" />
                            </a>
                            <span>marianfilms</span>
                        </li>
                        <li class="flex items-center gap-4">
                            <PhoneIcon class="h-7 w-auto" />
                            <a href="tel:+50374620617" class="hover:opacity-70">+503 7462-0617</a>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="flex justify-end mt-16 xl:mt-24">
                <a href="/" class="font-bold tracking-wide hover:opacity-70"><T value={ui.backToHome} /></a>
            </div>
        </div>
    </footer>
</Base>
